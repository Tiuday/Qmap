# ── Map ──────────────────────────────────────────────────────
# Free MapLibre + CARTO Dark Matter — works without any key
# Override with any MapLibre-compatible GL style URL
VITE_MAP_STYLE=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json

# ── Supabase ──────────────────────────────────────────────────
# 1. Create a free project at https://supabase.com
# 2. Run supabase/schema.sql in your project's SQL Editor
# 3. Copy your credentials from Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
